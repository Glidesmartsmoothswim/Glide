# ============================================================
# GLIDE — .env.local  (ESEMPIO)
# onda dopo onda
# ------------------------------------------------------------
# COME SI USA:
#  1. Copia questo file e rinominalo in ".env.local" (senza .example)
#  2. Incolla i valori veri presi dalle dashboard (istruzioni sotto ogni voce)
#  3. NON caricarlo mai su GitHub. Next.js lo ignora già di default.
#
# REGOLA D'ORO:
#  - Le variabili che iniziano con NEXT_PUBLIC_ finiscono nel BROWSER
#    → possono essere "pubbliche" (chiavi non pericolose).
#  - Tutte le altre restano SOLO sul server → sono SEGRETE.
#    Non metterle MAI in un componente che gira nel browser.
# ============================================================


# ---------- APP ----------
# In locale resta così. In produzione diventa il tuo dominio (es. https://glide.swim)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GLIDE


# ---------- SUPABASE (database + login) ----------
# Dove trovarle: Supabase → progetto → Settings → API
# URL del progetto (pubblico)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Chiave "anon" (pubblica, usata dal browser con la RLS attiva)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...INCOLLA_QUI...
# Chiave "service_role" (SEGRETA — bypassa la RLS). Solo lato server:
# webhook Stripe, job automatici. Non finisce MAI nel browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...INCOLLA_QUI...


# ---------- STRIPE (pagamenti: abbonamenti + birra €5) ----------
# Dove trovarle: Stripe → Developers → API keys (usa la modalità TEST all'inizio)
# Chiave pubblica (browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...INCOLLA_QUI...
# Chiave segreta (server)
STRIPE_SECRET_KEY=sk_test_...INCOLLA_QUI...
# Segreto del webhook (server). Lo ottieni quando crei il webhook
# oppure con "stripe listen" in locale.
STRIPE_WEBHOOK_SECRET=whsec_...INCOLLA_QUI...

# ID dei prezzi (Stripe → Product catalog → crea i prodotti, poi copia i "Price ID")
# Abbonamenti ricorrenti mensili:
STRIPE_PRICE_OPEN=price_...          # Canale Open  — € 29 / mese
STRIPE_PRICE_OPEN_WATER=price_...    # Open Water   — € 79 / mese
STRIPE_PRICE_ELITE=price_...         # Elite 1:1    — € 129 / mese
# Pagamento singolo (una tantum):
STRIPE_PRICE_BIRRA=price_...         # "Offrimi una birra" — € 5 (analisi video Open)


# ---------- RESEND (email di notifica) ----------
# Dove trovarla: Resend → API Keys
RESEND_API_KEY=re_...INCOLLA_QUI...
# Mittente delle email (dominio da verificare in Resend prima di andare live)
EMAIL_FROM=onda@glide.swim


# ---------- VIDEO IN PRODUZIONE (opzionale, solo quando scali) ----------
# In demo NON servono: i video stanno in Supabase Storage.
# Attivali solo quando i video crescono, per evitare crash/costi di banda.
# MUX_TOKEN_ID=
# MUX_TOKEN_SECRET=
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_STREAM_TOKEN=


# ============================================================
# PROMEMORIA SICUREZZA
#  - Verifica che ".env.local" sia dentro .gitignore (in Next.js c'è già).
#  - Su Vercel questi valori NON si caricano da file: si incollano in
#    Project → Settings → Environment Variables.
#  - Se una chiave segreta finisce online per sbaglio, rigenerala subito.
# ============================================================
